{
  "$schema": "https://design-tokens.org/schema/v1.0.0.json",
  "name": "NueroUI",
  "version": "1.0.0",
  "prefix": "nuero",
  "themes": [
    "default",
    "light",
    "high-contrast",
    "outdoor",
    "car-hud"
  ],
  "colors": {
    "background": {
      "primary": {
        "default": "#0B0E17",
        "light": "#F0F4FF"
      },
      "secondary": {
        "default": "#131829",
        "light": "#E4E8F0"
      },
      "elevated": {
        "default": "#1A2035",
        "light": "#FFFFFF"
      },
      "overlay": {
        "default": "#212A45",
        "light": "#D8DDE8"
      },
      "input": {
        "default": "#0F121E",
        "light": "#ECEFF5"
      },
      "hover": {
        "default": "#1E2540",
        "light": "#E8EDF5"
      },
      "active": {
        "default": "#252D4A",
        "light": "#DEE2EC"
      },
      "disabled": {
        "default": "#0D1019",
        "light": "#EAECF0"
      }
    },
    "accent": {
      "primary": {
        "default": "#00D4FF"
      },
      "secondary": {
        "default": "#7B61FF"
      },
      "tertiary": {
        "default": "#FF6B35"
      }
    },
    "functional": {
      "success": "#00E676",
      "warning": "#FFB300",
      "danger": "#FF3D71",
      "info": "#00D4FF"
    },
    "text": {
      "primary": {
        "default": "#F0F4FF",
        "light": "#0B0E17"
      },
      "secondary": {
        "default": "#8892B0",
        "light": "#4A5578"
      },
      "tertiary": {
        "default": "#4A5578",
        "light": "#8892B0"
      },
      "inverse": {
        "default": "#0B0E17"
      },
      "link": "#00D4FF"
    },
    "border": {
      "default": {
        "default": "rgba(255,255,255,0.08)"
      },
      "hover": {
        "default": "rgba(0,212,255,0.35)"
      },
      "focus": "#00D4FF",
      "active": {
        "default": "rgba(123,97,255,0.5)"
      },
      "subtle": {
        "default": "rgba(255,255,255,0.04)"
      }
    }
  },
  "typography": {
    "fonts": {
      "display": "'Outfit', 'Noto Sans SC', system-ui",
      "body": "'Source Sans 3', 'PingFang SC', 'Microsoft YaHei', sans-serif",
      "mono": "'JetBrains Mono', 'Fira Code', monospace"
    },
    "sizes": {
      "2xs": "0.625rem",
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "2rem",
      "4xl": "2.5rem",
      "5xl": "3rem"
    },
    "weights": {
      "light": 300,
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "spacing": {
    "0": "0",
    "px": "0.0625rem",
    "0-5": "0.125rem",
    "1": "0.25rem",
    "1-5": "0.375rem",
    "2": "0.5rem",
    "2-5": "0.625rem",
    "3": "0.75rem",
    "3-5": "0.875rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "7": "1.75rem",
    "8": "2rem",
    "9": "2.25rem",
    "10": "2.5rem",
    "12": "3rem",
    "14": "3.5rem",
    "16": "4rem",
    "20": "5rem",
    "24": "6rem",
    "32": "8rem"
  },
  "borderRadius": {
    "none": "0",
    "sm": "4px",
    "md": "8px",
    "lg": "16px",
    "xl": "24px",
    "2xl": "32px",
    "full": "9999px"
  },
  "transition": {
    "duration": {
      "instant": "0ms",
      "fast": "80ms",
      "normal": "150ms",
      "slow": "250ms",
      "slower": "400ms",
      "slowest": "600ms"
    },
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)",
      "inOut": "cubic-bezier(0.4, 0, 0.2, 1)",
      "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "bounce": "cubic-bezier(0.68, -0.55, 0.265, 1.55)"
    }
  },
  "shadow": {
    "xs": "0 1px 2px rgba(0,0,0,0.4)",
    "sm": "0 1px 4px rgba(0,0,0,0.5)",
    "md": "0 4px 12px rgba(0,0,0,0.55)",
    "lg": "0 8px 24px rgba(0,0,0,0.65)",
    "xl": "0 16px 48px rgba(0,0,0,0.75)",
    "inner": "inset 0 1px 3px rgba(0,0,0,0.4)",
    "glow": "0 0 24px rgba(0,212,255,0.2)"
  },
  "glow": {
    "primary": "0 0 20px rgba(0,212,255,0.35)",
    "secondary": "0 0 20px rgba(123,97,255,0.35)",
    "success": "0 0 16px rgba(0,230,118,0.35)",
    "warning": "0 0 16px rgba(255,179,0,0.35)",
    "danger": "0 0 16px rgba(255,61,113,0.5)",
    "gold": "0 0 20px rgba(201,168,76,0.3)"
  },
  "zIndex": {
    "base": 0,
    "raised": 10,
    "dropdown": 100,
    "sticky": 200,
    "fixed": 300,
    "modal": 400,
    "toast": 500,
    "tooltip": 600
  },
  "component": {
    "height": {
      "xs": "24px",
      "sm": "32px",
      "md": "40px",
      "lg": "48px",
      "xl": "56px",
      "2xl": "64px"
    },
    "width": {
      "sm": "80px",
      "md": "120px",
      "lg": "200px",
      "xl": "280px",
      "full": "100%"
    }
  },
  "aliases": {
    "$aliasSchema": "https://design-tokens.org/schema/v1.0.0.json#alias",
    "button": {
      "primary": {
        "background": "{colors.accent.primary}",
        "text": "{colors.text.inverse}",
        "border": "{colors.accent.primary}",
        "hover": {
          "background": "{colors.accent.primary}",
          "shadow": "{glow.primary}"
        }
      },
      "secondary": {
        "background": "{colors.accent.secondary}",
        "text": "{colors.text.inverse}",
        "border": "{colors.accent.secondary}"
      },
      "ghost": {
        "background": "transparent",
        "text": "{colors.accent.primary}",
        "border": "transparent"
      }
    },
    "input": {
      "default": {
        "background": "{colors.background.input}",
        "border": "{colors.border.default}",
        "text": "{colors.text.primary}",
        "placeholder": "{colors.text.tertiary}"
      },
      "focus": {
        "border": "{colors.border.focus}",
        "shadow": "{glow.primary}"
      },
      "error": {
        "border": "{colors.functional.danger}",
        "shadow": "{glow.danger}"
      }
    },
    "card": {
      "elevated": {
        "background": "{colors.background.elevated}",
        "shadow": "{shadow.md}",
        "border": "{colors.border.subtle}"
      },
      "primary": {
        "background": "{colors.background.secondary}",
        "shadow": "{shadow.sm}",
        "border": "{colors.border.default}"
      }
    },
    "badge": {
      "success": {
        "background": "{colors.functional.success}",
        "backgroundLight": "rgba(0,230,118,0.15)",
        "text": "{colors.functional.success}"
      },
      "warning": {
        "background": "{colors.functional.warning}",
        "backgroundLight": "rgba(255,179,0,0.15)",
        "text": "{colors.functional.warning}"
      },
      "danger": {
        "background": "{colors.functional.danger}",
        "backgroundLight": "rgba(255,61,113,0.15)",
        "text": "{colors.functional.danger}"
      },
      "info": {
        "background": "{colors.functional.info}",
        "backgroundLight": "rgba(0,212,255,0.15)",
        "text": "{colors.functional.info}"
      }
    },
    "navigation": {
      "sidebar": {
        "background": "{colors.background.secondary}",
        "item": {
          "default": {
            "background": "transparent",
            "text": "{colors.text.secondary}"
          },
          "hover": {
            "background": "{colors.background.hover}",
            "text": "{colors.text.primary}"
          },
          "active": {
            "background": "{colors.background.active}",
            "text": "{colors.accent.primary}"
          }
        }
      }
    }
  }
}
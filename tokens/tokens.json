{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "NueroUI",
  "version": "1.0.0",
  "date": "2026-04-19",
  "output": "Hermes01",
  "tokenSets": {
    "color": {
      "background": {
        "primary":   { "$value": "#0B0E17", "type": "color", "description": "深海蓝黑·主背景" },
        "secondary": { "$value": "#131829", "type": "color", "description": "卡片/面板" },
        "elevated":  { "$value": "#1A2035", "type": "color", "description": "悬浮层" },
        "overlay":   { "$value": "#212A45", "type": "color", "description": "模态遮罩" },
        "input":     { "$value": "#0F121E", "type": "color", "description": "输入框" },
        "hover":     { "$value": "#1E2540", "type": "color" },
        "active":    { "$value": "#252D4A", "type": "color" },
        "disabled":  { "$value": "#0D1019", "type": "color" }
      },
      "accent": {
        "primary":   { "$value": "#00D4FF", "type": "color", "description": "科技青" },
        "secondary": { "$value": "#7B61FF", "type": "color", "description": "能量紫" },
        "tertiary":  { "$value": "#FF6B35", "type": "color", "description": "警示橙" }
      },
      "functional": {
        "success": { "$value": "#00E676", "type": "color" },
        "warning": { "$value": "#FFB300", "type": "color" },
        "danger":  { "$value": "#FF3D71", "type": "color" },
        "info":    { "$value": "#00D4FF", "type": "color" }
      },
      "chinese": {
        "vermilion": { "$value": "#E8344A", "type": "color", "description": "朱红" },
        "ink":       { "$value": "#1A1A2E", "type": "color", "description": "墨黑" },
        "gold":      { "$value": "#C9A84C", "type": "color", "description": "墨金" },
        "jade":     { "$value": "#00C48C", "type": "color", "description": "翠玉" }
      },
      "text": {
        "primary":   { "$value": "#F0F4FF", "type": "color" },
        "secondary": { "$value": "#8892B0", "type": "color" },
        "tertiary":  { "$value": "#4A5578", "type": "color" },
        "inverse":   { "$value": "#0B0E17", "type": "color" },
        "link":      { "$value": "#00D4FF", "type": "color" }
      },
      "border": {
        "default":  { "$value": "rgba(255,255,255,0.08)", "type": "color" },
        "hover":   { "$value": "rgba(0,212,255,0.35)", "type": "color" },
        "focus":   { "$value": "#00D4FF", "type": "color" },
        "active":  { "$value": "rgba(123,97,255,0.50)", "type": "color" },
        "subtle":  { "$value": "rgba(255,255,255,0.04)", "type": "color" }
      }
    },
    "typography": {
      "font": {
        "display": { "$value": "'Outfit', 'Noto Sans SC', system-ui, sans-serif", "type": "fontFamily" },
        "body":     { "$value": "'Inter', 'PingFang SC', 'Microsoft YaHei', system-ui, sans-serif", "type": "fontFamily" },
        "mono":     { "$value": "'JetBrains Mono', 'Fira Code', monospace", "type": "fontFamily" }
      },
      "size": {
        "2xs":  { "$value": "0.625rem", "type": "dimension" },
        "xs":   { "$value": "0.75rem",  "type": "dimension" },
        "sm":   { "$value": "0.875rem", "type": "dimension" },
        "base": { "$value": "1rem",     "type": "dimension" },
        "lg":   { "$value": "1.125rem", "type": "dimension" },
        "xl":   { "$value": "1.25rem",  "type": "dimension" },
        "2xl":  { "$value": "1.5rem",   "type": "dimension" },
        "3xl":  { "$value": "2rem",     "type": "dimension" },
        "4xl":  { "$value": "2.5rem",   "type": "dimension" },
        "5xl":  { "$value": "3rem",     "type": "dimension" }
      },
      "weight": {
        "light":    { "$value": "300", "type": "fontWeight" },
        "normal":   { "$value": "400", "type": "fontWeight" },
        "medium":   { "$value": "500", "type": "fontWeight" },
        "semibold": { "$value": "600", "type": "fontWeight" },
        "bold":     { "$value": "700", "type": "fontWeight" }
      },
      "lineHeight": {
        "none":     { "$value": "1",     "type": "lineHeight" },
        "tight":    { "$value": "1.25",  "type": "lineHeight" },
        "snug":     { "$value": "1.375", "type": "lineHeight" },
        "normal":   { "$value": "1.5",   "type": "lineHeight" },
        "relaxed":  { "$value": "1.625", "type": "lineHeight" },
        "loose":    { "$value": "2",     "type": "lineHeight" }
      }
    },
    "spacing": {
      "0":   { "$value": "0",          "type": "dimension" },
      "px":  { "$value": "0.0625rem",  "type": "dimension" },
      "0-5": { "$value": "0.125rem",   "type": "dimension" },
      "1":   { "$value": "0.25rem",    "type": "dimension" },
      "1-5": { "$value": "0.375rem",   "type": "dimension" },
      "2":   { "$value": "0.5rem",     "type": "dimension" },
      "2-5": { "$value": "0.625rem",   "type": "dimension" },
      "3":   { "$value": "0.75rem",    "type": "dimension" },
      "3-5": { "$value": "0.875rem",   "type": "dimension" },
      "4":   { "$value": "1rem",       "type": "dimension" },
      "5":   { "$value": "1.25rem",    "type": "dimension" },
      "6":   { "$value": "1.5rem",     "type": "dimension" },
      "7":   { "$value": "1.75rem",    "type": "dimension" },
      "8":   { "$value": "2rem",       "type": "dimension" },
      "9":   { "$value": "2.25rem",    "type": "dimension" },
      "10":  { "$value": "2.5rem",     "type": "dimension" },
      "12":  { "$value": "3rem",       "type": "dimension" },
      "14":  { "$value": "3.5rem",     "type": "dimension" },
      "16":  { "$value": "4rem",       "type": "dimension" },
      "20":  { "$value": "5rem",       "type": "dimension" },
      "24":  { "$value": "6rem",       "type": "dimension" },
      "32":  { "$value": "8rem",       "type": "dimension" }
    },
    "radius": {
      "none":  { "$value": "0",        "type": "borderRadius" },
      "sm":    { "$value": "4px",      "type": "borderRadius" },
      "md":    { "$value": "8px",      "type": "borderRadius" },
      "lg":    { "$value": "16px",     "type": "borderRadius" },
      "xl":    { "$value": "24px",     "type": "borderRadius" },
      "2xl":   { "$value": "32px",     "type": "borderRadius" },
      "full":  { "$value": "9999px",   "type": "borderRadius" }
    },
    "shadow": {
      "xs":       { "$value": "0 1px 2px rgba(0,0,0,0.4)",       "type": "boxShadow" },
      "sm":       { "$value": "0 1px 4px rgba(0,0,0,0.5)",       "type": "boxShadow" },
      "md":       { "$value": "0 4px 12px rgba(0,0,0,0.55)",     "type": "boxShadow" },
      "lg":       { "$value": "0 8px 24px rgba(0,0,0,0.65)",     "type": "boxShadow" },
      "xl":       { "$value": "0 16px 48px rgba(0,0,0,0.75)",   "type": "boxShadow" },
      "inner":    { "$value": "inset 0 1px 3px rgba(0,0,0,0.4)", "type": "boxShadow" },
      "glow":     { "$value": "0 0 24px rgba(0,212,255,0.2)",    "type": "boxShadow" }
    },
    "glow": {
      "primary":   { "$value": "0 0 20px rgba(0,212,255,0.35)",  "type": "boxShadow" },
      "secondary": { "$value": "0 0 20px rgba(123,97,255,0.35)", "type": "boxShadow" },
      "success":   { "$value": "0 0 16px rgba(0,230,118,0.35)",  "type": "boxShadow" },
      "warning":   { "$value": "0 0 16px rgba(255,179,0,0.35)",  "type": "boxShadow" },
      "danger":    { "$value": "0 0 16px rgba(255,61,113,0.5)", "type": "boxShadow" },
      "gold":      { "$value": "0 0 20px rgba(201,168,76,0.3)",  "type": "boxShadow" }
    },
    "motion": {
      "duration": {
        "instant":  { "$value": "0ms",    "type": "duration" },
        "fast":      { "$value": "80ms",   "type": "duration" },
        "normal":    { "$value": "150ms",  "type": "duration" },
        "slow":      { "$value": "250ms",  "type": "duration" },
        "slower":    { "$value": "400ms",  "type": "duration" },
        "slowest":   { "$value": "600ms",  "type": "duration" }
      },
      "easing": {
        "default":   { "$value": "cubic-bezier(0.4, 0, 0.2, 1)",    "type": "cubic-bezier" },
        "in":        { "$value": "cubic-bezier(0.4, 0, 1, 1)",        "type": "cubic-bezier" },
        "out":       { "$value": "cubic-bezier(0, 0, 0.2, 1)",        "type": "cubic-bezier" },
        "inOut":     { "$value": "cubic-bezier(0.4, 0, 0.2, 1)",      "type": "cubic-bezier" },
        "spring":    { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "type": "cubic-bezier" },
        "bounce":    { "$value": "cubic-bezier(0.68, -0.55, 0.265, 1.55)", "type": "cubic-bezier" }
      }
    },
    "component": {
      "button": {
        "height": {
          "xs": { "$value": "24px",  "type": "dimension" },
          "sm": { "$value": "32px",  "type": "dimension" },
          "md": { "$value": "40px",  "type": "dimension" },
          "lg": { "$value": "48px",  "type": "dimension" },
          "xl": { "$value": "56px",  "type": "dimension" },
          "2xl":{ "$value": "64px",  "type": "dimension" }
        }
      },
      "zIndex": {
        "base":     { "$value": "0",   "type": "number" },
        "raised":   { "$value": "10",  "type": "number" },
        "dropdown": { "$value": "100", "type": "number" },
        "sticky":   { "$value": "200", "type": "number" },
        "fixed":    { "$value": "300", "type": "number" },
        "modal":    { "$value": "400", "type": "number" },
        "toast":    { "$value": "500", "type": "number" },
        "tooltip":  { "$value": "600", "type": "number" }
      }
    }
  }
}
